# Copy this file to `.env.local` and adjust if needed. Never commit `.env.local`.

# Base URL of the Django REST API.
# The NEXT_PUBLIC_ prefix exposes this variable to the browser (required for
# client-side fetch calls).
#
# Development (default):
NEXT_PUBLIC_API_BASE_URL=http://192.168.2.149:8000
#
# Production (point at your deployed backend URL):
# NEXT_PUBLIC_API_BASE_URL=https://api.yourapp.com
