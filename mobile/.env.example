# API base URL — copy this file to .env and set the correct value for your target.
#
# Per-target host rules:
#   Flutter web (Chrome)      : http://localhost:8000
#   Android emulator          : http://10.0.2.2:8000        (emulator loopback alias)
#   iOS simulator             : http://localhost:8000
#   Physical Android/iOS device: http://<dev-machine-LAN-IP>:8000
#
# The LAN IP is whatever `ipconfig` (Windows) / `ifconfig` (macOS/Linux) reports
# for your Wi-Fi adapter. Both the device and the dev machine must be on the same
# network.
#
# To pin the Flutter web port: flutter run -d chrome --web-port 5000
API_BASE_URL=http://localhost:8000
